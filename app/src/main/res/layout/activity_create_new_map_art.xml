<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:fillViewport="true"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"

        android:orientation="vertical"
        android:background="@color/light_cream"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/titleTV"
                tools:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_centerVertical="true"
                style="@style/Text.ScreenTitle"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:text="@string/create_new_art" />

        </RelativeLayout>

        <FrameLayout android:id="@+id/mapArtsContainer"
            android:background="@color/dark_d5"
            android:layout_width="match_parent"
            android:layout_marginHorizontal="16dp"
            android:visibility="invisible"
            tools:visibility="visible"
            android:layout_height="200dp" >

        </FrameLayout>

        <Space
            android:id="@+id/stateErrorS"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.5"
            android:visibility="gone"
            tools:visibility="gone"
            />

        <ImageView
            android:id="@+id/errorImageIV"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="56dp"
            android:layout_gravity="center"
            tools:visibility="gone"
            android:src="@drawable/ic_error_general"/>

        <TextView
            android:id="@+id/errorTextTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textAlignment="center"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            tools:visibility="gone"
            style="@style/Text.MiddleScreenInfoText"
            tools:text="It seems like something wrong happened. Please try again" />

        <TextView
            android:id="@+id/cityCountryTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Text.Title"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            tools:visibility="visible"
            app:layout_constraintTop_toBottomOf="@id/mapArtsContainer"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Salvador - Casa" />

        <TextView
            android:id="@+id/descriptionTV"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/artTitleTV"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            style="@style/Text.GraySubTitle"
            tools:visibility="gone"
            android:layout_marginHorizontal="16dp"
            tools:text="Uma arte criada a partir da minha casa easdasdasdasdasdadadadsadam salvador no politeama" />

        <LinearLayout
            android:id="@+id/aiPoweredLL"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginHorizontal="16dp"
            android:paddingVertical="4dp"
            android:visibility="gone"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/aiTextTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/green_darker"
                android:textSize="14sp"
                android:fontFamily="@font/nunito_extra_bold"
                android:layout_gravity="center_vertical"
                android:text="@string/create_description_with_ai"/>

            <ProgressBar
                android:id="@+id/loadingAIIndicatorPB"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                android:theme="@style/Theme.GenerateMapArts.ProgressBarTheme"
                android:layout_gravity="center"/>

            <ImageView
                android:id="@+id/aiPoweradeIV"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_ai_powerade"
                />

        </LinearLayout>

        <com.airbnb.lottie.LottieAnimationView
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:id="@+id/loadingIndicatorLAV"
            app:lottie_rawRes="@raw/loading_globe"
            app:lottie_loop="true"
            android:visibility="gone"
            tools:visibility="gone"
            android:layout_gravity="center"
            app:lottie_autoPlay="true"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            />

        <manoellribeiro.dev.martp.core.components.MartpButton
            android:id="@+id/actionMB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:title="@string/save_art"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cornerRadius="50dp"
            style="@style/MartpButton.Primary"/>

    </LinearLayout>

</ScrollView>

